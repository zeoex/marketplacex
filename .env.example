# ─── APP ───────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=MarketPlaceX
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ─── DATABASE ──────────────────────────────────────────────
DB_USER=mpx_user
DB_PASSWORD=mpx_password
DB_NAME=marketplacex
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://mpx_user:mpx_password@localhost:5432/marketplacex

# ─── REDIS ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=mpx_redis_pass
REDIS_URL=redis://:mpx_redis_pass@localhost:6379

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── OAUTH ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3001/auth/facebook/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key

# ─── SMS / OTP ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# ─── EMAIL ─────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
EMAIL_FROM=noreply@marketplacex.com
RESEND_API_KEY=your-resend-api-key

# ─── PAYMENTS ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PLATFORM_FEE_PERCENT=5

PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

MERCADOPAGO_ACCESS_TOKEN=your-mp-access-token
MERCADOPAGO_PUBLIC_KEY=your-mp-public-key

# ─── STORAGE ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# or use local storage:
UPLOAD_DRIVER=local
UPLOAD_MAX_SIZE_MB=10

# ─── GOOGLE MAPS ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-key

# ─── CAPTCHA ───────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=your-recaptcha-secret
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# ─── FRONTEND (NEXT.JS) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# ─── RATE LIMITING ─────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── ADMIN ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@marketplacex.com
ADMIN_PASSWORD=Admin123!
